"NotificationsGuideBlockedAll" = "உமது சாதன அமைவுகளில் இச்செயலிக்கான அறிவிப்புகள் தடுக்கப்பட்டுள்ளன.\n\nஅறிவிப்புகளை இயக்க:\n• முறைமை-அறிவிப்பு அமைவுகளைத் தட்டவும்.\n• இச்சாதன அறிவிப்புகளை இயக்கவும்.";
"NotificationsGuideBlockedApp" = "அமைவுகளில் இச்செயலிக்கான அறிவிப்புகள் தடுக்கப்பட்டுள்ளன. அறிவிப்புச் செயல்பாட்டை இயக்க முறைமை-அறிவிப்பு அமைவுகளை மாற்றுக.";
"NotificationsGuideBlockedCategory" = "அமைவுகளில் தற்போதைய கணக்குக்கான அறிவிப்புகள் முடக்கப்பட்டுள்ளது.\n\nஅறிவிப்புகளை இயக்க:\n• முறைமை-அறிவிப்பு அமைவுகளைத் தட்டவும்\n• \"%1$s\" அறிவிப்பு வகை கண்டுபிடிக்கவும்.\n• அறிவிப்புகளைச் செயல்பாட்டை மாற்றுக.";
"NotificationsGuideCategoryLimit" = "**கிராமியம் ஃ** அறிவிப்பு வகைகளின் அமைவு வரம்பு காரணமாக இக்கணக்கிற்கான சில அறிவிப்புகளைக் காட்ட முடியவில்லை.\n\nதயவுசெய்து இவற்றை உறுதிப்படுத்தவும்:\n• அனைத்து முறைமை மேம்படுத்தல்களும் நிறுவப்பட்டுள்ளன\n• கிராமியம் ஃ மேம்படுத்தப்பட்ட நிலையில் உள்ளது\n• முறைமை அமைவுகளில் அறிவிப்புக் கட்டுப்பாடுகள் எதுவும் இல்லை.\n\nமேலே உள்ள படிகள் உதவவில்லை என்றால், உமது சாதனத்திற்கான சரிசெய்தல் உதவிக்குறிப்புகளை @tgandroidtests -ல் கேட்கலாம் அல்லது கிராமியம் ஃ -ஐ மீண்டும் நிறுவவும், இது இப்பிழையைத் தீர்க்க உதவும், ஆனால் உங்கள் கணக்கில் மீண்டும் உள்நுழைய வேண்டும்.";
"NotificationsGuideCategoryLimitErrorChat" = "**கிராமியம் ஃ** அறிவிப்பு வகைகளின் அமைவு வரம்பு காரணமாக %1$s-இன் சில அறிவிப்புகளைக் காட்ட முடியவில்லை.\n\nதயவுசெய்து இவற்றை உறுதிப்படுத்தவும்:\n• அனைத்து முறைமை மேம்படுத்தல்களும் நிறுவப்பட்டுள்ளன\n• கிராமியம் ஃ மேம்படுத்தப்பட்ட நிலையில் உள்ளது\n• முறைமை அமைவுகளில் அறிவிப்புக் கட்டுப்பாடுகள் எதுவும் இல்லை.\n\nமேலே உள்ள படிகள் உதவவில்லை என்றால், உமது சாதனத்திற்கான சரிசெய்தல் உதவிக்குறிப்புகளை @tgandroidtests -ல் கேட்கலாம் அல்லது கிராமியம் ஃ -ஐ மீண்டும் நிறுவவும், இது இப்பிழையைத் தீர்க்க உதவும், ஆனால் உங்கள் கணக்கில் மீண்டும் உள்நுழைய வேண்டும்.";
"NotificationsGuideError" = "**கிராமியம் ஃ** அறியப்படாத முறைமை பிழை காரணமாக இந்தக் கணக்கிற்கான சில அறிவிப்புகளைக் காட்ட முடியவில்லை.\n\nதயவுசெய்து இவற்றை உறுதிப்படுத்துக:\n• அனைத்து முறைமை மேம்படுத்தல்களும் நிறுவப்பட்டுள்ளன\n• கிராமியம் ஃ புதுப்பித்த நிலையில் உள்ளது\n• முறைமை அமைவுகளில் அறிவிப்புக் கட்டுப்பாடுகள் எதுவும் இல்லை.\n\nமேலே கூறியவற்றால் பயனில்லை எனில், விரிவான பிழை அறிக்கையை @tgandroidtests உடன் பகிரலாம் அல்லது உங்கள் சாதனத்திற்கான சரிசெய்தல் உதவிக்குறிப்புகளைப் பார்க்கவும்.";
"NotificationsGuideErrorChat" = "**கிராமியம் ஃ** %1$s-லிருந்து அறியப்படாத முறைமை பிழை காரணமாகச் சில அறிவிப்புகளைக் காட்ட முடியவில்லை.\n\nதயவுசெய்து இவற்றை உறுதிப்படுத்துக:\nஅனைத்து முறைமை மேம்படுத்தல்களும் நிறுவப்பட்டுள்ளன\nகிராமியம் ஃ புதுப்பித்த நிலையில் உள்ளது\nமுறைமைஅமைவுகளில் அறிவிப்புக் கட்டுப்பாடுகள் எதுவும் இல்லை\n\nமேலே கூறியவற்றால் பயனில்லை எனில், விரிவான பிழை அறிக்கையை @tgandroidtests உடன் பகிரலாம் அல்லது உங்கள் சாதனத்திற்கான சரிசெய்தல் உதவிக்குறிப்புகளைப் பார்க்கவும்.";
"NotificationsGuideFirebaseError" = "**ஃபயர்பேஸ் பணியங்கள்** பிழையின் காரணத்தால் சரியாகச் செயல்படத் தவறிவிட்டது: %1$s\n\nஅறிவிப்புகள் மிகவும் தாமதமாக வரலாம் அல்லது அவை வராமல் போகலாம்.\n\nதயவுசெய்து இவற்றை உறுதிப்படுத்தவும்:\n• கூகுள் ஆட்டத்தின் பணியங்கள் நிறுவப்பட்டு, புதுப்பித்த நிலையில் உள்ளனவா: https://support.google.com/googleplay/answer/9037938?hl=ta\n• கிராமியம் ஃ புதுப்பித்த நிலையில் உள்ளதா\n• ஃபயர்பேஸ் பணியங்கள் இயக்கப்பட்டு உள்ளனவா\n• உங்கள் இணைய பணியம் அல்லது DNS வழங்குநரால் அவை தடுக்கப்படவில்லையா\n• உங்களிடம் ஃபயர்வால் அல்லது விளம்பரத்தைத் தடுக்கும் மென்பொருள் இருந்தால், ஃபயர்பேஸ் களங்கள் அனுமதிப்பட்டியலில் சேர்க்கப்பட்டுள்ளதா\n• இப்பக்க உலாவியில் 404 தகவலைப் பார்க்கிறீர்களா: https://firebaseinstallations.googleapis.com/\n• கணினியின் தேதி மற்றும் நேரம் சரியானதா\n• உமது சாதனத்தை மறுதொடக்கம் செய்த பிறகு சிக்கல் நீங்கியதா\n• அனைத்து முறைமை புதுப்பிப்புகளும் நிறுவப்பட்டுள்ளனவா\n• கிராமியம் ஃ இன் **அதிகாரப்பூர்வ** பதிப்பைப் பயன்படுத்துகிறீர்களா: @tgx_log\n\nமேலே உள்ள படிகள் உதவவில்லை என்றால், நீங்கள் நம்பும் VPNஐப் பயன்படுத்தி மீண்டும் முயற்சிக்கவும், ஏனெனில் இது உங்கள் பிராந்தியத்தின் அதிகார இணைய தணிக்கை காரணமாக இருக்கலாம்.";
"NotificationsGuideFirebaseUnavailable" = "கூகுள் ஆட்டப் பணியங்கள் கிடைக்கவில்லை. அவை நிறுவப்பட்டுள்ளதா & புதுப் பதிப்பிலுள்ளதா எனச் சரிபார்க்கவும்.\n\nஅவை இல்லாததால், அறிவிப்புகள் பெற நீண்ட தாமதமாகிறது அல்லது அறிவிப்பு வருவதில்லை.";
"NotificationsGuidePermission" = "உமது முறைமை அமைவுகளில் இச்செயலியினால் வரும் அறிவிப்புகள் தடுக்கப்பட்டுள்ளன.\n\nஅறிவிப்புகளை இயக்க:\n• முறைமை அமைவுகள் – செயலிகள் – கிராமியம் ஃ என்பதற்குச் செல்க.\n• அறிவிப்புகளைத் தட்டவும் – அறிவிப்புகளை அனுமதிக்கவும்.";
"NotificationsGuideSyncAppOff" = "இச்செயலிக்கான தரவு ஒத்திசைவு முடக்கப்பட்டுள்ளதால் இதை மூடும்போது அறிவிப்புகள் வராது.\n\nஉங்கள் சாதனத்தில் மின்கலன் தேர்வுமுறை மூலம் தரவு ஒத்திசைவு மறைமுகமாக நிறுத்தப் பட்டிருக்கலாம்.";
