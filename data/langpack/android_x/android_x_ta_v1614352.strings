"json_1_name" = "சுருதி";
"json_1_text1" = "கொண்டு வா! நான் இதற்காக **வாழ்கிறேன்**!";
"json_1_text2" = "சுருதி, நாம் சில புதுத் தாளங்களைக் கண்டுபிடிக்க வேண்டும் 🎶.";
"json_1_text3" = "ஆம், நீங்கள் இன்று தொழில்நுட்ப இசையின் வாரிசு! அசை சீர் தாண்டி இசைத்தமிழ் சுவைத்திடுக!";
"json_1_text4" = "நான் இப்போது உங்களைத் தீவிரமாக எடுத்துக்கொள்ள முடியாது.";
"json_2_name1" = "தேனீ";
"json_2_name2" = "அங்குச மணி";
"json_2_name3" = "ஜூலியன் அசாங்கே";
"json_2_name4" = "பாணர்";
"json_2_text1" = "நிச்சயமாக இது இங்கே பாதுகாப்பாக இருக்கிறதா?";
"json_2_text2" = "ஆம், நிச்சயமாக, கவலைப்படாதே.";
"json_2_text3" = "ஐயா அங்குச மணி, உளவுத்துறை இதையும் படிக்குமா?😄";
"json_2_text4" = "பொறுத்தருள்க, இந்த உரையாடலை இணையத்தில் வெளியிட வேண்டும்.";
"json_2_text5" = "காத்திருங்கள், நாம் பணம் ஈட்டியிருக்கலாம்!";
"json_2_title" = "வார விடுமுறை திட்டம்";
"json_3_name" = "எலைன் லாக்ஹார்ட்";
"json_3_text1" = "ஏன் கிராமியம் குளிர்ச்சியானது?";
"json_3_text2" = "சரி, பார். கிராமியம் அதிவேகம் மற்றும் நீங்கள் அனைத்துச் சாதனங்களிலும் ஒரே நேரத்தில் பயன்படுத்தலாம் - தொலைப்பேசி, மடிக்கணினி, மேசைக் கணினி.";
"json_3_text3" = "😴";
"json_3_text4" = "இது கமுக்க அரட்டைகளைக் கொண்டது, அதாவது, இறுதிக்கு-இறுதி மறைகுறியானது!";
"json_3_text5" = "எதுவரை மறைகுறியானது??";
"json_3_text6" = "அடடா. மறந்துவிடு. ஒரு நேரத்தை அமைத்து, நேரம் முடிந்தவுடன் மறைந்துவிடும் தகவலை அனுப்பலாம். ஆஹா!";
"json_3_text7" = "😱🙈👍";
"json_4_name" = "விண்வெளி டேன்டி";
"json_4_text1" = "நீங்கள் இந்த அரட்டை முன்னோட்டத்தைக் காண்கிறீர்கள், ஏனெனில் நீங்கள் ஒரு **மொழிபெயர்ப்பாளர்**.\n\nஉங்கள் சொந்தக் காட்சிகளை எவ்வாறு உருவாக்குவது என்பதற்கான வழிகாட்டிகளை @tgx_android_translate-ல் காணலாம்.";
