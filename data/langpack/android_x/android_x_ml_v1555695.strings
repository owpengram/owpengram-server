"NotificationsGuideBlockedAll" = "ടെലിഗ്രാമിൽ നിന്നുള്ള അറിയിപ്പുകൾ സിസ്റ്റം സജ്ജീകരണങ്ങളിൽ ബ്ലോക്ക് ചെയ്തിരിക്കുന്നു.\n\nഅറിയിപ്പുകൾ പ്രവർത്തനക്ഷമമാക്കാൻ:\n• സിസ്റ്റം അറിയിപ്പ് ക്രമീകരണങ്ങൾ ടാപ്പുചെയ്യുക\n• «അറിയിപ്പുകൾ കാണിക്കുക» ടോഗിൾ ഓൺ ചെയ്യുക .";
"NotificationsGuideBlockedApp" = "ടെലിഗ്രാമിൽ നിന്നുള്ള അറിയിപ്പുകൾ സിസ്റ്റം സജ്ജീകരണങ്ങളിൽ തടഞ്ഞിരിക്കുന്നു. അവ അൺബ്ലോക്ക് ചെയ്യാൻ സിസ്റ്റം അറിയിപ്പ് ക്രമീകരണങ്ങൾ ടാപ്പുചെയ്യുക.";
"NotificationsGuideBlockedCategory" = "നിലവിലെ അക്കൌണ്ടിനായുള്ള അറിയിപ്പുകൾ സിസ്റ്റം ക്രമീകരണങ്ങളിൽ പ്രവർത്തനരഹിതമാക്കിയിരിക്കുന്നു.\n\nഅറിയിപ്പുകൾ പ്രവർത്തനക്ഷമമാക്കാൻ:\n• സിസ്റ്റം അറിയിപ്പ് ക്രമീകരണങ്ങൾ ടാപ്പുചെയ്യുക\n• %1$s അറിയിപ്പ് വിഭാഗം കണ്ടെത്തുക.\n• അറിയിപ്പുകൾ തടഞ്ഞത് മാറ്റാൻ ടോഗിൾ ഓൺ ചെയ്യുക.";
"NotificationsGuideError" = "ഒരു അജ്ഞാത സിസ്റ്റം പിശക് കാരണം **ടെലിഗ്രാം എക്സ്** ന് ഈ അക്കൗണ്ടിനായുള്ള ചില അറിയിപ്പുകൾ പ്രദർശിപ്പിക്കാൻ കഴിഞ്ഞില്ല.\n\nദയവുചെയ്ത് ഉറപ്പുവരുത്തുക:\n• എല്ലാ സിസ്റ്റം അപ്\u200cഡേറ്റുകളും ഇൻസ്റ്റാൾ ചെയ്\u200cതു\n• ടെലിഗ്രാം എക്സ് അപ്ഡേറ്റഡ് ആണ്\n• സിസ്റ്റം ക്രമീകരണങ്ങളിൽ അറിയിപ്പ് നിയന്ത്രണങ്ങളൊന്നുമില്ല.\n\nമുകളിലുള്ള പറഞ്ഞവ സഹായിക്കുന്നില്ലെങ്കിൽ, വിശദമായ പിശക് റിപ്പോർട്ട് @tgandroidtests ൽ പങ്കിടുക, അല്ലെങ്കിൽ നിങ്ങളുടെ ഉപകരണത്തിനായുള്ള ട്രബിൾഷൂട്ടിംഗ് ടിപ്പുകൾക്കായി തിരയുക.";
"NotificationsGuideErrorChat" = "ഒരു അജ്ഞാത സിസ്റ്റം പിശക് കാരണം **ടെലിഗ്രാം എക്സ്** ന് %1$s എന്ന അക്കൗണ്ടിനായുള്ള ചില അറിയിപ്പുകൾ പ്രദർശിപ്പിക്കാൻ കഴിഞ്ഞില്ല.\n\nദയവുചെയ്ത് ഉറപ്പുവരുത്തുക:\n• എല്ലാ സിസ്റ്റം അപ്\u200cഡേറ്റുകളും ഇൻസ്റ്റാൾ ചെയ്\u200cതു\n• ടെലിഗ്രാം എക്സ് അപ്ഡേറ്റഡ് ആണ്\n• സിസ്റ്റം ക്രമീകരണങ്ങളിൽ അറിയിപ്പ് നിയന്ത്രണങ്ങളൊന്നുമില്ല.\n\nമുകളിലുള്ള പറഞ്ഞവ സഹായിക്കുന്നില്ലെങ്കിൽ, വിശദമായ പിശക് റിപ്പോർട്ട് @tgandroidtests ൽ പങ്കിടുക, അല്ലെങ്കിൽ നിങ്ങളുടെ ഉപകരണത്തിനായുള്ള ട്രബിൾഷൂട്ടിംഗ് ടിപ്പുകൾക്കായി തിരയുക.";
"NotificationsGuideFirebaseUnavailable" = "Google Play സേവനങ്ങൾ ലഭ്യമല്ല. അവ ഇൻസ്റ്റാൾ ചെയ്തിട്ടുണ്ടോ എന്നും അപ് ടു ഡേറ്റ് ആണോ എന്നും ദയവായി പരിശോധിക്കുക.\n\nഅവ ലഭ്യമല്ലെങ്കിൽ അറിയിപ്പുകൾ വലിയ കാലതാമസം നേരിടാനോ അല്ലെങ്കിൽ ലഭിക്കാതിരിക്കാനോ ഇടയാകുന്നതാണ്.";
