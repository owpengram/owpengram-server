"SponsoredMessageInfoDescription1" = "בניגוד לאפליקציות אחרות, טלגרם לעולם לא משתמשת בנתונים האישיים שלך כדי להתאים פרסומות. הודעות ממומנות בטלגרם מבוססות רק על נושא הערוץ הציבורי בו הן מוצגות. זאת אומרת שאיננו כורים או מנתחים פרטי משתמשים בכדי להציג פרסומות, וכל המשתמשים שצופים בערוץ מסוים בטלגרם יראו את אותה ההודעה הממומנת.";
"SponsoredMessageInfoDescription2" = "בניגוד לאפליקציות אחרות, טלגרם לא עוקבת האם לחצת על הודעה ממומנת, ואינה מכוונת אותן אליך בהתאם לפעילות שלך. אנו חוסמים קישורים חיצוניים בהודעות ממומנות כדי לוודא שגופים צד שלישי לא יוכלו לרגל אחרי המשתמשים שלנו. אנו מאמינים שלכולם הזכות לפרטיות, ועל פלטפורמות טכנולוגיות לכבד זאת.";
"SponsoredMessageInfoDescription3" = "טלגרם מספקת שירות חינמי ובלתי מוגבל למאות מליוני משתמשים, הכולל עלויות שרתים ותעבורה משמעותיות. כדי להישאר עצמאיים ונאמנים לערכים שלנו, טלגרם פיתחה כלי כדי לקדם הודעות שמתחשבות בפרטיות המשתמש. אנו מזמינים מפרסמים אחראיים כאן:";
"SponsoredMessageInfoDescription4" = "הודעות ממומנות נמצאות כרגע במצב בדיקה. ברגע שהן יושרו במלואן ויאפשרו לטלגרם לכסות את העלויות הבסיסיות שלה, נתחיל לחלוק את ההכנסה מהפרסומות עם בעלי הערוצים בהן הן מוצגות.\n\nמודעות באינטרנט לא צריכות להיות שם נרדף להפרת פרטיות המשתמש. הבה נגדיר כיצד חברה טכנולוגית צריכה לפעול – ביחד.";
